# SlawdCode environment configuration
# Copy this file to .env and source it, or export variables directly in your shell.
#
# Authentication
# ==============
# PREFERRED: Run 'slawdcode-auth' once for browser-based OAuth login.
#            No API key needed — credentials are stored securely in ~/.claude/
#
# FALLBACK (CI / automation only):
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Container image to use (default: slawdcode:latest — built locally with 'make build')
# SLAWDCODE_IMAGE=slawdcode:latest

# Container runtime — auto-detected (podman preferred, then docker)
# SLAWDCODE_RUNTIME=podman

# Extra flags passed directly to 'podman run' / 'docker run'
# Examples:
#   Corporate proxy:
#     SLAWDCODE_EXTRA_ARGS=--env HTTPS_PROXY=http://proxy.corp.example.com:8080
#
#   Custom CA certificate:
#     SLAWDCODE_EXTRA_ARGS=--env NODE_EXTRA_CA_CERTS=/certs/ca.pem --volume /etc/ssl/corp-ca.pem:/certs/ca.pem:ro
#
# SLAWDCODE_EXTRA_ARGS=
